<?xml version="1.0" encoding="UTF-8" ?>

<templates xml:space="preserve">

	<t
		t-name="muk_web_appsbar.WebClient"
		t-inherit="web.WebClient"
		t-inherit-mode="extension"
	>
	    <xpath expr="//NavBar" position="after">
	    	<div class="t4_sidebar_area" t-att-class="{ 't4_sidebar_removed': sidebarState.mode === 'hidden' }">
	    		<t t-if="sidebarState.visible">
		    		<ResizablePanel
		    			handleSide="'end'"
		    			class="'t4_sidebar_panel'"
		    			onResize.bind="_onSidebarResize"
		    			initialWidth="sidebarState.width"
		    			minWidth="68">
		    			<AppsBar/>
		    		</ResizablePanel>
	    		</t>
	    		<div class="t4_sidebar_toggle_anchor" t-if="sidebarState.mode !== 'hidden'">
		    		<button t-on-click="_toggleSidebar"
		    				class="t4_sidebar_toggle d-none d-lg-flex"
		    				title="Toggle Sidebar (Ctrl+Shift+Left)">
		    			<svg class="t4_toggle_svg" viewBox="0 0 20 56" xmlns="http://www.w3.org/2000/svg">
		    				<path class="t4_toggle_shape" d="M0 0 C0 0, 0 4, 4 8 C8 12, 14 16, 14 24 L14 32 C14 40, 8 44, 4 48 C0 52, 0 56, 0 56 L0 0Z"/>
		    			</svg>
		    			<i class="fa t4_toggle_icon"
		    				t-att-class="{ 'fa-angle-left': sidebarState.visible, 'fa-angle-right': !sidebarState.visible }"/>
		    		</button>
	    		</div>
	    	</div>
	    </xpath>
	</t>

</templates>
