<?xml version="1.0" encoding="UTF-8" ?>

<templates xml:space="preserve">

	<t
		t-name="muk_web_appsbar.WebClient"
		t-inherit="web.WebClient"
		t-inherit-mode="extension"
	>
	    <xpath expr="//NavBar" position="after">
	    	<div class="t4_sidebar_area">
	    		<t t-if="sidebarState.visible">
		    		<ResizablePanel
		    			handleSide="'end'"
		    			class="'t4_sidebar_panel'"
		    			onResize.bind="_onSidebarResize"
		    			initialWidth="sidebarState.width"
		    			minWidth="68">
		    			<AppsBar/>
		    		</ResizablePanel>
	    		</t>
	    		<button t-on-click="_toggleSidebar"
	    				class="t4_sidebar_toggle d-none d-lg-flex"
	    				title="Toggle Sidebar (Esc)">
	    			<svg width="24" height="130" viewBox="0 0 24 130" fill="none"
	    				xmlns="http://www.w3.org/2000/svg">
	    				<path d="M1.38462 18.7168L1.8301 22.7112C2.26003 26.5663 4.27932 30.0671 7.40111 32.3694C11.5512 35.4301 14.0007 40.2802 14.0007 45.4369V82.4101C14.0007 87.7445 11.5406 92.7807 7.33313 96.0597C4.30939 98.4163 2.31544 101.852 1.76936 105.646L1.31152 108.828"
	    					stroke="currentColor" stroke-width="1"/>
	    				<path d="M1 21V21.1546C1 22.0457 1.14367 22.931 1.42547 23.7764L1.47964 23.9389C1.4932 23.9796 1.50962 24.0192 1.52879 24.0576C1.83879 24.6776 2.00233 25.3605 2.0068 26.0536L2.48837 100.697C2.49595 101.872 2.15172 103.022 1.5 104L1.48049 104.039C1.32729 104.345 1.20808 104.668 1.125 105L1 106V103.821V21Z"
	    					fill="var(--t4-toggle-bg, transparent)"/>
	    			</svg>
	    			<i class="fa position-absolute"
	    				t-att-class="{ 'fa-angle-left': sidebarState.visible, 'fa-angle-right': !sidebarState.visible }"/>
	    		</button>
	    	</div>
	    </xpath>
	</t>

</templates>
