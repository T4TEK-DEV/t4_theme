<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">

    <t t-name="t4_theme.ThemeSettingsAction">
        <div class="t4_ts d-flex flex-column h-100">
            <!-- Top Bar -->
            <div class="t4_ts_topbar d-flex align-items-center px-3 py-2 border-bottom bg-white">
                <button class="btn btn-sm btn-outline-secondary me-3" t-on-click="onBack">
                    <i class="fa fa-arrow-left me-1"/>Back
                </button>
                <h5 class="mb-0 flex-grow-1">
                    <i class="fa fa-paint-brush me-2 text-primary"/>Theme Settings
                </h5>
                <span t-if="state.saveStatus === 'saving'" class="text-warning me-2">
                    <i class="fa fa-circle-o-notch fa-spin me-1"/>Saving...
                </span>
                <span t-if="state.saveStatus === 'saved'" class="text-success me-2">
                    <i class="fa fa-check me-1"/>Saved
                </span>
                <button t-if="state.dirty" class="btn btn-sm btn-success" t-on-click="onSave">
                    <i class="fa fa-save me-1"/>Save Theme
                </button>
            </div>

            <!-- Main Content -->
            <div class="t4_ts_main d-flex flex-grow-1 overflow-hidden">

                <!-- LEFT: Settings Panel -->
                <div class="t4_ts_sidebar border-end bg-white">
                    <div class="p-3">
                        <!-- No component selected -->
                        <div t-if="!state.selectedComponent" class="text-center text-muted py-4">
                            <i class="fa fa-mouse-pointer fa-3x mb-3 d-block opacity-50"/>
                            <p class="fw-bold">Click a component</p>
                            <p class="small">Click any element in the preview to customize its appearance</p>
                        </div>

                        <!-- Component selected -->
                        <div t-if="state.selectedComponent">
                            <div class="d-flex align-items-center mb-3">
                                <button class="btn btn-sm btn-outline-secondary me-2" t-on-click="onDeselectComponent">
                                    <i class="fa fa-arrow-left"/>
                                </button>
                                <i t-attf-class="fa {{ state.selectedComponent.config.icon }} me-2 text-primary"/>
                                <strong t-out="state.selectedComponent.config.label"/>
                            </div>

                            <!-- Properties -->
                            <t t-foreach="state.selectedComponent.config.properties" t-as="prop" t-key="prop.key">
                                <div class="t4_ts_prop mb-3">
                                    <label class="t4_ts_prop_label">
                                        <t t-out="prop.label"/>
                                    </label>

                                    <!-- Slider -->
                                    <div t-if="prop.type === 'slider'" class="t4_ts_slider_row">
                                        <input type="range"
                                            t-att-min="prop.min" t-att-max="prop.max"
                                            t-att-value="getPropertyValue(prop)"
                                            t-att-data-css-var="prop.key"
                                            t-att-data-unit="prop.unit"
                                            t-on-input="onSliderInput"/>
                                        <input type="number"
                                            t-att-min="prop.min" t-att-max="prop.max"
                                            t-att-value="getPropertyValue(prop)"
                                            t-att-data-css-var="prop.key"
                                            t-att-data-unit="prop.unit"
                                            t-on-input="onSliderInput"/>
                                        <span class="t4_ts_unit" t-out="prop.unit"/>
                                    </div>

                                    <!-- Color -->
                                    <div t-if="prop.type === 'color'" class="t4_ts_color_row">
                                        <input type="color"
                                            t-att-value="getPropertyValue(prop) or '#ffffff'"
                                            t-att-data-css-var="prop.key"
                                            t-on-input="onColorInput"/>
                                        <input type="text"
                                            t-att-value="getPropertyValue(prop)"
                                            placeholder="#hex"
                                            t-att-data-css-var="prop.key"
                                            t-on-change="onColorInput"/>
                                    </div>

                                    <!-- Select -->
                                    <div t-if="prop.type === 'select'" class="t4_ts_select_row">
                                        <select class="form-select form-select-sm"
                                            t-att-data-css-var="prop.key"
                                            t-on-change="onSelectInput">
                                            <option value="">Default</option>
                                            <t t-foreach="prop.options" t-as="opt" t-key="opt.value">
                                                <option t-att-value="opt.value"
                                                    t-att-selected="getPropertyValue(prop) === opt.value">
                                                    <t t-out="opt.label"/>
                                                </option>
                                            </t>
                                        </select>
                                    </div>
                                </div>
                            </t>

                            <!-- Reset -->
                            <button class="btn btn-sm btn-outline-secondary w-100 mt-2" t-on-click="onResetComponent">
                                <i class="fa fa-undo me-1"/>Reset Component
                            </button>
                        </div>
                    </div>
                </div>

                <!-- RIGHT: Preview Area -->
                <div class="t4_ts_preview flex-grow-1 overflow-auto bg-light">
                    <!-- View Tabs -->
                    <div class="t4_ts_tabs d-flex border-bottom bg-white px-3">
                        <t t-foreach="viewTabs" t-as="tab" t-key="tab.key">
                            <button
                                t-attf-class="btn btn-sm me-1 my-1 {{ state.activeTab === tab.key ? 'btn-primary' : 'btn-outline-secondary' }}"
                                t-att-data-tab="tab.key"
                                t-on-click="onTabClick">
                                <i t-attf-class="fa {{ tab.icon }} me-1"/>
                                <t t-out="tab.label"/>
                            </button>
                        </t>
                    </div>

                    <!-- View Renderer -->
                    <div class="t4_ts_view_container p-3">
                        <View t-props="viewProps" t-key="state.activeTab"/>
                    </div>
                </div>
            </div>
        </div>
    </t>

</templates>
