<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <!--
        STT (số thứ tự) injection cho list view trong x2many.

        Layout cố định:
            [selector?] [handle?] [STT] [field columns...]

        Khi list có cột `widget="handle"`, STT chèn ngay SAU cột handle để
        thanh tay kéo (drag) đứng đầu — đúng convention list editable
        Odoo. Khi không có handle, STT là cell đầu tiên sau selector.

        Hai nhánh xpath dưới đây loại trừ nhau qua điều kiện `withHandleColumn`
        (renderer-level, set trong ListRenderer.setup) và `column.widget`
        (per-iteration). Mỗi render chỉ kích hoạt đúng 1 nhánh → tổng cell
        per row luôn = nbCols (đã patch +1 trong list_renderer_patch.js).

        Hàng "Add a line" và filler row tự động bù 1 cell qua patch
        `nbCols`/`getGroupNameCellColSpan` — không cần inject thêm <td/>.
    -->

    <t t-name="t4_theme.ListRendererSTTHead"
       t-inherit="web.ListRenderer"
       t-inherit-mode="extension">
        <!-- Không có cột handle: STT đứng đầu, ngay sau selector. -->
        <xpath expr="//thead/tr/t[@t-foreach='columns']" position="before">
            <th t-if="props.t4WithRowNumber and !withHandleColumn"
                class="o_t4_stt_col text-center align-middle"
                tabindex="-1"
                t-on-keydown="(ev) => this.onCellKeydown(ev)">
                STT
            </th>
        </xpath>
        <!-- Có cột handle: STT chèn ngay sau cột handle trong vòng foreach. -->
        <xpath expr="//thead/tr/t[@t-foreach='columns']" position="inside">
            <th t-if="props.t4WithRowNumber and column.widget === 'handle'"
                class="o_t4_stt_col text-center align-middle"
                tabindex="-1"
                t-on-keydown="(ev) => this.onCellKeydown(ev)">
                STT
            </th>
        </xpath>
    </t>

    <t t-name="t4_theme.ListRendererSTTRow"
       t-inherit="web.ListRenderer.RecordRow"
       t-inherit-mode="extension">
        <!-- Không có cột handle: STT đứng đầu, ngay sau selector. -->
        <xpath expr="//t[@t-foreach='getColumns(record)']" position="before">
            <td t-if="props.t4WithRowNumber and !withHandleColumn"
                class="o_t4_stt_cell text-center align-middle text-muted"
                t-on-keydown="(ev) => this.onCellKeydown(ev, group, record)"
                tabindex="-1">
                <t t-esc="t4GetRowNumber(record)"/>
            </td>
        </xpath>
        <!-- Có cột handle: STT chèn ngay sau cột handle trong vòng foreach. -->
        <xpath expr="//t[@t-foreach='getColumns(record)']" position="inside">
            <td t-if="props.t4WithRowNumber and column.widget === 'handle'"
                class="o_t4_stt_cell text-center align-middle text-muted"
                t-on-keydown="(ev) => this.onCellKeydown(ev, group, record)"
                tabindex="-1">
                <t t-esc="t4GetRowNumber(record)"/>
            </td>
        </xpath>
    </t>

</templates>
