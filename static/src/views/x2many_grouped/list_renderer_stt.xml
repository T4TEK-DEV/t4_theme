<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <!--
        STT (số thứ tự) column for x2many list views.

        STT is injected as a real entry in `this.columns` by the
        `getActiveColumns` patch in list_renderer_patch.js. The entry has
        `type: "t4_stt"` and `attrs.width: "48px"` so Odoo's
        `useMagicColumnWidths` hook treats it as a regular column — width
        is computed correctly and column-resize / min-max logic stays in
        sync with the rest of the columns.

        These template extensions add a `column.type === "t4_stt"` branch
        inside the standard column foreach in web's list_renderer.xml so
        the column renders a proper <th> / <td> at the right index.

        Important — t-if/t-else chaining:
            The thead foreach in upstream is
                <th t-if="column.type === 'field'">...</th>
                <th t-else=""/>
            Inserting our t-if between them would break the t-else
            pairing (it would chain to our new t-if, causing the legacy
            empty <th> to render whenever STT does). We therefore convert
            `t-else=""` to an explicit `t-if` with the complementary
            condition before inserting. Same constraint does not apply to
            the row template because it uses three independent t-ifs.
    -->

    <t t-name="t4_theme.ListRendererSTTHead"
       t-inherit="web.ListRenderer"
       t-inherit-mode="extension">
        <!-- Convert legacy t-else into explicit t-if so STT branch can be
             inserted without breaking the t-else pairing. -->
        <xpath expr="//thead/tr/t[@t-foreach='columns']/th[@t-else='']" position="attributes">
            <attribute name="t-else"/>
            <attribute name="t-if">column.type !== 'field' and column.type !== 't4_stt'</attribute>
        </xpath>
        <!-- Insert STT branch right after the 'field' branch. -->
        <xpath expr="//thead/tr/t[@t-foreach='columns']/th[@t-if=&quot;column.type === 'field'&quot;]" position="after">
            <th t-if="column.type === 't4_stt'"
                class="o_t4_stt_col text-center align-middle"
                tabindex="-1"
                t-on-keydown="(ev) => this.onCellKeydown(ev)">
                STT
            </th>
        </xpath>
    </t>

    <t t-name="t4_theme.ListRendererSTTRow"
       t-inherit="web.ListRenderer.RecordRow"
       t-inherit-mode="extension">
        <xpath expr="//t[@t-foreach='getColumns(record)']/t[@t-if=&quot;column.type === 'widget'&quot;]" position="after">
            <t t-if="column.type === 't4_stt'">
                <td class="o_data_cell o_t4_stt_cell text-center align-middle text-muted"
                    t-on-keydown="(ev) => this.onCellKeydown(ev, group, record)"
                    tabindex="-1">
                    <!-- Pass `list` từ template context (set bởi outer Rows
                         template qua `t-set list=group.list` trong t-call).
                         `list` = local subList chứa record này trực tiếp,
                         nên `list.records.indexOf(record)` ra đúng local idx
                         bất kể nesting depth. Tránh được mọi vấn đề lookup
                         qua map/walk groups vốn fail ở deep-nested level. -->
                    <t t-esc="t4GetRowNumber(record, list)"/>
                </td>
            </t>
        </xpath>
    </t>

    <!--
        Expose `group.t4Depth` lên DOM cho SCSS (indent + comment-thread
        tree lines). `t4Depth` được attach bởi x2many_grouped_adapter.js
        khi field `t4_tree_depth` có trong list view; nếu không có thì
        attribute = "0" — không ảnh hưởng layout default.
    -->
    <t t-name="t4_theme.ListRendererGroupRowDepth"
       t-inherit="web.ListRenderer.GroupRow"
       t-inherit-mode="extension">
        <xpath expr="//tr[@t-att-data-group-id='group.id']" position="attributes">
            <attribute name="t-att-data-t4-depth">group.t4Depth or 0</attribute>
        </xpath>
    </t>

    <!--
        Data row trong group cũng cần `data-t4-depth` để SCSS apply
        padding-left + vẽ tree line. Đọc trực tiếp từ field
        `t4_tree_depth` đã load (column_invisible vẫn được fetch).
    -->
    <t t-name="t4_theme.ListRendererRecordRowDepth"
       t-inherit="web.ListRenderer.RecordRow"
       t-inherit-mode="extension">
        <xpath expr="//tr[@class='o_data_row']" position="attributes">
            <attribute name="t-att-data-t4-depth">record.data.t4_tree_depth or 0</attribute>
        </xpath>
    </t>

    <!--
        Nested-group widget extensions (x2many_nested_group_adapter.js).
        Only active for groups that expose `t4DirectRecords` / `t4OpenInfo`
        — other grouped list views are unaffected since both attributes
        default to undefined and the `t-if` guards skip the patched code.

        1. Render direct records BEFORE sub-groups inside a parent group.
           Native Odoo only renders one of (records, sub-groups) per
           group; we render both when `list.t4DirectRecords` is set, so a
           parent creation header can show its direct lines AND nested
           sub-creation groups in the same parent.

        2. Open-record icon on group header: when `group.t4OpenInfo` is
           set, append a `<button>` (right-aligned via ms-auto) that
           opens the underlying record via the actionService.
    -->
    <t t-name="t4_theme.ListRendererNestedRowsDirectRecords"
       t-inherit="web.ListRenderer.Rows"
       t-inherit-mode="extension">
        <xpath expr="//t[@t-else='']/t[@t-foreach='list.groups']" position="before">
            <t t-if="list.t4DirectRecords">
                <t t-foreach="list.t4DirectRecords" t-as="record" t-key="record.id">
                    <t t-call="{{ constructor.recordRowTemplate }}"/>
                </t>
            </t>
        </xpath>
    </t>

    <t t-name="t4_theme.ListRendererNestedGroupRowOpen"
       t-inherit="web.ListRenderer.GroupRow"
       t-inherit-mode="extension">
        <!--
            Insert open button right BEFORE the group name text so it
            sits next to the header label.

            Anchor pick: the upstream `<t t-esc="group.displayName"/>` is
            the most stable anchor — the surrounding span uses
            `t-attf-class` (dynamic) so `hasclass('o_group_caret')` fails
            to match it, and `<t t-esc>` elements are addressable via
            their `t-esc` attribute in XPath.

            Visual:  ▼ [↗] PC/2026/00029 (8)
        -->
        <xpath expr="//t[@t-esc='group.displayName']" position="before">
            <button t-if="group.t4OpenInfo"
                    class="btn btn-link p-0 me-2 o_t4_group_open_btn"
                    title="Mở phiếu"
                    t-on-click.stop="(ev) => this.t4OpenGroupRecord(ev, group)"
                    tabindex="-1">
                <i class="fa fa-external-link" aria-hidden="true"/>
            </button>
        </xpath>
    </t>

</templates>
