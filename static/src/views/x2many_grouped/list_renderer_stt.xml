<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <!--
        STT (số thứ tự) injection cho list view trong x2many.

        STT luôn là cột đầu tiên SAU optional selector và TRƯỚC cột handle
        (nếu có). Layout cố định:
            [selector?] [STT] [handle?] [field columns...]

        Trước đây dùng 2 nhánh xpath rẽ theo `withHandleColumn` để chèn STT
        sau cột handle. Khi resequence (drag-drop), state nội bộ của Odoo
        thay đổi giữa các render → dual-condition xpath có thể rớt sai
        nhánh cho từng row → STT cell xuất hiện ở vị trí khác nhau giữa
        các row (extra/missing). Ép STT về vị trí cố định loại bỏ vấn đề.

        Hàng "Add a line" và filler row tự động bù 1 cell qua patch
        `nbCols` (list_renderer_patch.js) — không cần inject thêm <td/>.
    -->

    <t t-name="t4_theme.ListRendererSTTHead"
       t-inherit="web.ListRenderer"
       t-inherit-mode="extension">
        <xpath expr="//thead/tr/t[@t-foreach='columns']" position="before">
            <th t-if="props.t4WithRowNumber"
                class="o_t4_stt_col text-center align-middle"
                tabindex="-1"
                t-on-keydown="(ev) => this.onCellKeydown(ev)">
                STT
            </th>
        </xpath>
    </t>

    <t t-name="t4_theme.ListRendererSTTRow"
       t-inherit="web.ListRenderer.RecordRow"
       t-inherit-mode="extension">
        <xpath expr="//t[@t-foreach='getColumns(record)']" position="before">
            <td t-if="props.t4WithRowNumber"
                class="o_t4_stt_cell text-center align-middle text-muted"
                t-on-keydown="(ev) => this.onCellKeydown(ev, group, record)"
                tabindex="-1">
                <t t-esc="t4GetRowNumber(record)"/>
            </td>
        </xpath>
    </t>

</templates>
