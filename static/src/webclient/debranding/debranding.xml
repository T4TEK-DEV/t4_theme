<?xml version="1.0" encoding="UTF-8" ?>

<templates xml:space="preserve">

    <!-- Session Expired Dialog — replace "Odoo" -->
    <t t-name="t4_theme.SessionExpiredDialog"
       t-inherit="web.SessionExpiredDialog"
       t-inherit-mode="extension">
        <xpath expr="//Dialog" position="attributes">
            <attribute name="title">Phiên làm việc đã hết hạn</attribute>
        </xpath>
        <xpath expr="//p[contains(text(),'Odoo')]" position="replace">
            <p class="text-prewrap">Phiên làm việc đã hết hạn. Trang hiện tại sẽ được tải lại.</p>
        </xpath>
    </t>

    <!-- Push Notification alert — replace "Odoo" -->
    <t t-name="t4_theme.NotificationAlert"
       t-inherit="web.NotificationAlert"
       t-inherit-mode="extension">
        <xpath expr="//div[contains(@class,'alert')]" position="replace">
            <div t-if="isNotificationBlocked" class="alert alert-primary text-center">
                Thông báo đẩy đã bị chặn. Vui lòng bật trong cài đặt trình duyệt.
            </div>
        </xpath>
    </t>

    <!-- Upgrade Dialog — replace "Odoo Enterprise" with generic label -->
    <t t-name="t4_theme.UpgradeDialog"
       t-inherit="web.UpgradeDialog"
       t-inherit-mode="extension">
        <xpath expr="//Dialog" position="attributes">
            <attribute name="title">Tính năng nâng cao</attribute>
        </xpath>
    </t>

</templates>
