<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">

<t t-name="t4_theme.HomeMenu">
    <div t-ref="root" class="o_home_menu h-100 overflow-auto position-relative"
        t-att-class="{ o_ios_app: state.isIosApp, t4_hm_edit_mode: editMode }">

        <!-- Grid overlay (edit mode) -->
        <div t-if="editMode" class="t4_hm_grid_overlay"/>

        <!-- Edit toolbar (edit mode, draggable) -->
        <div t-if="editMode" class="t4_hm_toolbar" t-ref="toolbar"
            t-on-mousedown="onToolbarDrag" t-on-touchstart="onToolbarDrag">
            <span class="t4_hm_toolbar_grip" title="Kéo thanh công cụ"><i class="fa fa-ellipsis-v"/></span>
            <button class="btn btn-sm" t-att-class="logoState.visible ? 'btn-light' : 'btn-outline-light opacity-50'"
                t-on-click.stop="() => this.toggleWidget('logo')" title="Bật/tắt Logo">
                <i class="fa fa-image me-1"/>Logo
            </button>
            <button class="btn btn-sm" t-att-class="timeState.visible ? 'btn-light' : 'btn-outline-light opacity-50'"
                t-on-click.stop="() => this.toggleWidget('time')" title="Bật/tắt Giờ">
                <i class="fa fa-clock-o me-1"/>Giờ
            </button>
            <button class="btn btn-sm" t-att-class="dateState.visible ? 'btn-light' : 'btn-outline-light opacity-50'"
                t-on-click.stop="() => this.toggleWidget('date')" title="Bật/tắt Ngày">
                <i class="fa fa-calendar me-1"/>Ngày
            </button>
            <span class="t4_hm_toolbar_sep"/>
            <button class="btn btn-sm btn-outline-light" t-on-click.stop="compactApps" title="Tự động thu gọn">
                <i class="fa fa-th me-1"/>Thu gọn
            </button>
            <button class="btn btn-sm btn-outline-warning" t-on-click.stop="resetHomeMenu" title="Đặt lại mặc định">
                <i class="fa fa-undo me-1"/>Đặt lại
            </button>
        </div>

        <!-- Company Logo -->
        <div t-if="logoState.visible" class="t4_hm_widget"
            t-att-class="{ 't4_hm_draggable': editMode }"
            t-att-style="logoStyle"
            t-on-mousedown="onLogoDrag" t-on-touchstart="onLogoDrag">
            <img t-att-src="companyLogoUrl" class="t4_hm_logo" alt="Logo" draggable="false"/>
            <div t-if="editMode" class="t4_hm_widget_resize" t-on-mousedown.stop="onLogoResize" t-on-touchstart.stop="onLogoResize">
                <i class="fa fa-expand"/>
            </div>
            <span t-if="editMode" class="t4_hm_widget_label">Logo</span>
        </div>

        <!-- Time (HH:MM:SS AM/PM) — separate draggable -->
        <div t-if="timeState.visible" class="t4_hm_widget"
            t-att-class="{ 't4_hm_draggable': editMode }"
            t-att-style="timeStyle"
            t-on-mousedown="onTimeDrag" t-on-touchstart="onTimeDrag">
            <div class="t4_hm_clock_time_row">
                <span class="t4_hm_clock_hours" t-esc="timeState.hours"/>
                <span class="t4_hm_clock_sep">:</span>
                <span class="t4_hm_clock_minutes" t-esc="timeState.minutes"/>
                <span class="t4_hm_clock_sep">:</span>
                <span class="t4_hm_clock_seconds" t-esc="timeState.seconds"/>
                <span class="t4_hm_clock_period" t-esc="timeState.period"/>
            </div>
            <div t-if="editMode" class="t4_hm_widget_resize" t-on-mousedown.stop="onTimeResize" t-on-touchstart.stop="onTimeResize">
                <i class="fa fa-expand"/>
            </div>
            <span t-if="editMode" class="t4_hm_widget_label">Time</span>
        </div>

        <!-- Date — separate draggable -->
        <div t-if="dateState.visible" class="t4_hm_widget"
            t-att-class="{ 't4_hm_draggable': editMode }"
            t-att-style="dateStyle"
            t-on-mousedown="onDateDrag" t-on-touchstart="onDateDrag">
            <div class="t4_hm_clock_date" t-esc="dateState.text"/>
            <div t-if="editMode" class="t4_hm_widget_resize" t-on-mousedown.stop="onDateResize" t-on-touchstart.stop="onDateResize">
                <i class="fa fa-expand"/>
            </div>
            <span t-if="editMode" class="t4_hm_widget_label">Date</span>
        </div>

        <div class="container">
            <input t-ref="input" type="text" class="o_search_hidden visually-hidden w-auto" data-allow-hotkeys="true" t-on-input="_onInputSearch" t-on-blur="_onInputBlur" t-on-compositionstart="_onCompositionStart"
                role="combobox"
                t-att-aria-activedescendant="'result_app_' + state.focusedIndex"
                t-att-aria-expanded="displayedApps.length ? 'true' : 'false'"
                aria-autocomplete="list" aria-haspopup="listbox"/>
            <div t-if="displayedApps.length" t-ref="grid" role="listbox"
                 class="t4_hm_grid user-select-none mt-3" t-att-style="gridStyle">
                <t t-foreach="gridCells" t-as="cell" t-key="cell.row + '_' + cell.col">
                    <!-- App cell -->
                    <div t-if="cell.app" class="t4_hm_cell t4_hm_cell_occupied"
                         t-att-class="{
                            't4_hm_cell_dragging': state.draggingApp === cell.app.xmlid,
                            't4_hm_cell_highlight': editMode and state.highlightRow === cell.row and state.highlightCol === cell.col
                         }"
                         t-att-data-row="cell.row" t-att-data-col="cell.col"
                         t-att-style="cellStyle(cell)"
                         t-on-mousedown="(ev) => this.onAppGridDrag(ev, cell.app)"
                         t-on-touchstart="(ev) => this.onAppGridDrag(ev, cell.app)">
                        <a t-att-id="'result_app_' + cell.appIndex" role="option"
                            t-att-aria-selected="state.focusedIndex === cell.appIndex ? 'true' : 'false'"
                            class="o_app o_menuitem d-flex flex-column rounded-3 justify-content-start align-items-center w-100 p-1 p-md-2"
                            t-att-class="{o_focused: state.focusedIndex === cell.appIndex, 't4_hm_app_editable': editMode}"
                            t-att-data-menu-xmlid="cell.app.xmlid"
                            t-att-href="editMode ? undefined : cell.app.href"
                            t-on-click.prevent="() => this._onAppClick(cell.app)">
                            <div class="position-relative">
                                <img t-if="cell.app.webIconData" class="o_app_icon" t-attf-src="{{cell.app.webIconData}}" draggable="false"/>
                                <div t-else="" class="o_app_icon position-relative d-flex justify-content-center align-items-center p-2 ratio ratio-1x1"
                                    t-attf-style="background-color: {{cell.app.webIcon.backgroundColor}};">
                                    <i t-attf-class="{{cell.app.webIcon.iconClass}} position-relative w-auto h-auto" t-attf-style="color: {{cell.app.webIcon.color}};"/>
                                </div>
                                <button t-if="editMode" class="t4_edit_icon btn btn-sm btn-primary position-absolute"
                                        title="Sửa biểu tượng" t-on-click="(ev) => this.onEditIconClick(ev, cell.app)">
                                    <i class="fa fa-pencil"/>
                                </button>
                            </div>
                            <div class="o_caption w-100 text-center text-truncate mt-2" t-esc="cell.app.label or cell.app.name"/>
                        </a>
                    </div>
                    <!-- Empty cell (edit mode only) -->
                    <div t-elif="editMode" class="t4_hm_cell t4_hm_cell_empty"
                         t-att-class="{'t4_hm_cell_highlight': state.highlightRow === cell.row and state.highlightCol === cell.col}"
                         t-att-data-row="cell.row" t-att-data-col="cell.col"
                         t-att-style="cellStyle(cell)">
                        <div class="t4_hm_cell_placeholder">
                            <i class="fa fa-plus"/>
                        </div>
                    </div>
                </t>
            </div>
            <div t-elif="!displayedApps.length" id="result_menu_0" role="option" aria-selected="true" class="o_no_result">
                Không có kết quả
            </div>
        </div>
    </div>
</t>

<t t-name="t4_theme.HomeMenu.CommandPalette.Footer">
    <span>
        <span class='fw-bolder text-primary'>MẸO</span> — mở từ bất kỳ đâu bằng <span t-esc="controlKey" class='fw-bolder text-primary'/> + <span class='fw-bolder text-primary'>K</span>
    </span>
</t>

</templates>
