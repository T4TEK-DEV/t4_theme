<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">

<t t-name="t4_theme.IconEditorDialog">
    <Dialog title="'Sửa biểu tượng ứng dụng'" size="'md'">
        <div class="t4_icon_editor">
            <!-- Preview -->
            <div class="t4_icon_preview d-flex justify-content-center mb-4">
                <div t-if="editedAppData.type === 'base64' and editedAppData.webIconData"
                     class="t4_icon_preview_box">
                    <img t-att-src="editedAppData.webIconData" class="rounded-3" style="width:80px;height:80px;object-fit:cover;"/>
                </div>
                <div t-else=""
                     class="t4_icon_preview_box d-flex align-items-center justify-content-center rounded-3"
                     t-attf-style="width:80px;height:80px;background-color:{{editedAppData.backgroundColor || '#875A7B'}};">
                    <i t-attf-class="{{editedAppData.iconClass || 'fa fa-home'}} fa-2x"
                       t-attf-style="color:{{editedAppData.color || '#FFFFFF'}};"/>
                </div>
            </div>

            <!-- Tabs -->
            <ul class="nav nav-tabs mb-3">
                <li class="nav-item">
                    <a class="nav-link" t-att-class="{ active: state.activeTab === 'custom_icon' }"
                       href="#" t-on-click.prevent="() => this.onTabChange('custom_icon')">Biểu tượng tùy chỉnh</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" t-att-class="{ active: state.activeTab === 'base64' }"
                       href="#" t-on-click.prevent="() => this.onTabChange('base64')">Tải ảnh lên</a>
                </li>
            </ul>

            <!-- Custom Icon Tab -->
            <div t-if="state.activeTab === 'custom_icon'">
                <!-- Background Color -->
                <div class="mb-3">
                    <label class="form-label fw-bold">Màu nền</label>
                    <div class="d-flex flex-wrap gap-1">
                        <button t-foreach="bgColors" t-as="color" t-key="color"
                                class="t4_color_swatch border-0 rounded-2"
                                t-att-class="{ 'ring-2 ring-primary': editedAppData.backgroundColor === color }"
                                t-attf-style="width:28px;height:28px;background-color:{{color}};cursor:pointer;"
                                t-on-click="() => this.onBgColorClick(color)"/>
                    </div>
                </div>

                <!-- Icon Color -->
                <div class="mb-3">
                    <label class="form-label fw-bold">Màu biểu tượng</label>
                    <div class="d-flex flex-wrap gap-1">
                        <button t-foreach="iconColors" t-as="color" t-key="color"
                                class="t4_color_swatch border rounded-2"
                                t-att-class="{ 'ring-2 ring-primary': editedAppData.color === color }"
                                t-attf-style="width:28px;height:28px;background-color:{{color}};cursor:pointer;"
                                t-on-click="() => this.onIconColorClick(color)"/>
                    </div>
                </div>

                <!-- Icon Class -->
                <div class="mb-3">
                    <label class="form-label fw-bold">Biểu tượng</label>
                    <div class="d-flex flex-wrap gap-1">
                        <button t-foreach="iconClasses" t-as="ic" t-key="ic"
                                class="t4_icon_choice border rounded-2 d-flex align-items-center justify-content-center"
                                t-att-class="{ 'bg-primary text-white': editedAppData.iconClass === ic }"
                                style="width:36px;height:36px;cursor:pointer;"
                                t-on-click="() => this.onIconClassClick(ic)">
                            <i t-att-class="ic"/>
                        </button>
                    </div>
                </div>
            </div>

            <!-- Upload Tab -->
            <div t-if="state.activeTab === 'base64'">
                <div class="text-center py-4">
                    <p class="text-muted mb-3">Tải lên ảnh PNG (khuyến nghị: 120x120px)</p>
                    <FileInput t-props="fileInputProps" onUpload.bind="onFileUploaded">
                        <button class="btn btn-outline-primary">
                            <i class="fa fa-upload me-1"/> Chọn tệp
                        </button>
                    </FileInput>
                </div>
            </div>
        </div>

        <t t-set-slot="footer">
            <button class="btn btn-primary" t-on-click="saveIcon">Lưu</button>
            <button class="btn btn-secondary" t-on-click="props.close">Hủy</button>
        </t>
    </Dialog>
</t>

</templates>
