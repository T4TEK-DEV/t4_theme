<?xml version="1.0" encoding="UTF-8" ?>

<templates xml:space="preserve">

    <t t-name="t4_theme.ThemeSystray">
        <!-- Systray Button -->
        <div class="o_theme_systray">
            <button class="btn o_theme_systray_btn" t-on-click="togglePanel" title="Theme Settings">
                <i class="fa fa-lg fa-paint-brush"/>
            </button>
        </div>

        <!-- Portal to body — escapes navbar CSS inheritance -->
        <t t-portal="'body'">
            <!-- Backdrop -->
            <div t-if="state.open" class="t4_theme_backdrop" t-on-click="onClickBackdrop"/>

            <!-- Right Sidebar Panel -->
            <div t-ref="panel" class="t4_theme_panel" t-att-class="{ open: state.open }">

            <!-- Header -->
            <div class="t4_theme_panel_header">
                <h6 class="mb-0 fw-bold">
                    <i class="fa fa-paint-brush me-2"/>Theme Settings
                </h6>
                <button class="btn btn-sm btn-close" t-on-click="closePanel"/>
            </div>

            <div class="t4_theme_panel_body">

                <!-- ====== Dark Mode ====== -->
                <div class="t4_section">
                    <div class="d-flex align-items-center justify-content-between">
                        <span class="t4_section_label">
                            <i class="fa fa-moon-o me-2"/>Dark Mode
                        </span>
                        <div class="form-check form-switch mb-0">
                            <input type="checkbox" class="form-check-input"
                                t-att-checked="state.darkMode"
                                t-on-change="onToggleDarkMode"/>
                        </div>
                    </div>
                </div>

                <!-- ====== Theme Presets ====== -->
                <div class="t4_section">
                    <span class="t4_section_label d-block mb-2">
                        <i class="fa fa-swatchbook me-2"/>Theme Preset
                    </span>
                    <div class="d-flex flex-wrap gap-2">
                        <t t-foreach="presets" t-as="preset" t-key="preset.key">
                            <button class="t4_preset_btn"
                                t-attf-class="{{ state.currentPreset === preset.key ? 'active' : '' }}"
                                t-attf-style="background-color: {{ preset.color }}"
                                t-att-title="preset.label"
                                t-on-click="() => this.onSelectPreset(preset.key)">
                                <i t-if="state.currentPreset === preset.key" class="fa fa-check"/>
                            </button>
                        </t>
                    </div>
                </div>

                <!-- ====== Layout Options ====== -->
                <div class="t4_section">
                    <span class="t4_section_label d-block mb-2">
                        <i class="fa fa-columns me-2"/>Layout
                    </span>

                    <!-- Sidebar -->
                    <div class="mb-2">
                        <small class="text-muted d-block mb-1">Sidebar</small>
                        <div class="btn-group w-100" role="group">
                            <t t-foreach="sidebarOptions" t-as="opt" t-key="opt.key">
                                <button type="button" class="btn btn-sm"
                                    t-attf-class="{{ state.sidebarType === opt.key ? 'btn-primary' : 'btn-outline-secondary' }}"
                                    t-on-click="() => this.onSelectSidebar(opt.key)">
                                    <t t-out="opt.label"/>
                                </button>
                            </t>
                        </div>
                    </div>

                    <!-- Chatter -->
                    <div class="mb-2">
                        <small class="text-muted d-block mb-1">Chatter</small>
                        <div class="btn-group w-100" role="group">
                            <t t-foreach="chatterOptions" t-as="opt" t-key="opt.key">
                                <button type="button" class="btn btn-sm"
                                    t-attf-class="{{ state.chatterPosition === opt.key ? 'btn-primary' : 'btn-outline-secondary' }}"
                                    t-on-click="() => this.onSelectChatter(opt.key)">
                                    <t t-out="opt.label"/>
                                </button>
                            </t>
                        </div>
                    </div>

                    <!-- Dialog -->
                    <div>
                        <small class="text-muted d-block mb-1">Dialog</small>
                        <div class="btn-group w-100" role="group">
                            <t t-foreach="dialogOptions" t-as="opt" t-key="opt.key">
                                <button type="button" class="btn btn-sm"
                                    t-attf-class="{{ state.dialogSize === opt.key ? 'btn-primary' : 'btn-outline-secondary' }}"
                                    t-on-click="() => this.onSelectDialog(opt.key)">
                                    <t t-out="opt.label"/>
                                </button>
                            </t>
                        </div>
                    </div>
                </div>

                <!-- ====== Brand Colors ====== -->
                <div class="t4_section">
                    <span class="t4_section_label d-block mb-2">
                        <i class="fa fa-tint me-2"/>Brand Colors
                    </span>
                    <div class="t4_color_row">
                        <label>Brand</label>
                        <input type="color" t-att-value="state.colorBrand"
                            t-on-change="(ev) => this.onColorChange('brand', ev)"/>
                    </div>
                    <div class="t4_color_row">
                        <label>Primary</label>
                        <input type="color" t-att-value="state.colorPrimary"
                            t-on-change="(ev) => this.onColorChange('primary', ev)"/>
                    </div>
                </div>

                <!-- ====== Context Colors ====== -->
                <div class="t4_section">
                    <span class="t4_section_label d-block mb-2">
                        <i class="fa fa-circle-o me-2"/>Context Colors
                    </span>
                    <div class="t4_color_row">
                        <label>Success</label>
                        <input type="color" t-att-value="state.colorSuccess"
                            t-on-change="(ev) => this.onColorChange('success', ev)"/>
                    </div>
                    <div class="t4_color_row">
                        <label>Info</label>
                        <input type="color" t-att-value="state.colorInfo"
                            t-on-change="(ev) => this.onColorChange('info', ev)"/>
                    </div>
                    <div class="t4_color_row">
                        <label>Warning</label>
                        <input type="color" t-att-value="state.colorWarning"
                            t-on-change="(ev) => this.onColorChange('warning', ev)"/>
                    </div>
                    <div class="t4_color_row">
                        <label>Danger</label>
                        <input type="color" t-att-value="state.colorDanger"
                            t-on-change="(ev) => this.onColorChange('danger', ev)"/>
                    </div>
                </div>

                <!-- ====== Sidebar Colors ====== -->
                <div class="t4_section">
                    <span class="t4_section_label d-block mb-2">
                        <i class="fa fa-bars me-2"/>Sidebar Colors
                    </span>
                    <div class="t4_color_row">
                        <label>Background</label>
                        <input type="color" t-att-value="state.colorAppbarBg"
                            t-on-change="(ev) => this.onColorChange('appbar_background', ev)"/>
                    </div>
                    <div class="t4_color_row">
                        <label>Text</label>
                        <input type="color" t-att-value="state.colorAppbarText"
                            t-on-change="(ev) => this.onColorChange('appbar_text', ev)"/>
                    </div>
                    <div class="t4_color_row">
                        <label>Active</label>
                        <input type="color" t-att-value="state.colorAppbarActive"
                            t-on-change="(ev) => this.onColorChange('appbar_active', ev)"/>
                    </div>
                    <div class="t4_color_row">
                        <label>Menu Text</label>
                        <input type="color" t-att-value="state.colorAppsmenuText"
                            t-on-change="(ev) => this.onColorChange('appsmenu_text', ev)"/>
                    </div>
                </div>

                <!-- ====== Branding ====== -->
                <div class="t4_section">
                    <span class="t4_section_label d-block mb-2">
                        <i class="fa fa-building-o me-2"/>Branding
                    </span>

                    <!-- Browser Title -->
                    <div class="mb-3">
                        <small class="text-muted d-block mb-1">Browser Title</small>
                        <input type="text" class="form-control form-control-sm"
                            t-att-value="state.webTitle"
                            t-on-change="onChangeWebTitle"
                            placeholder="My Company"/>
                    </div>

                    <!-- Logo -->
                    <div class="mb-3">
                        <small class="text-muted d-block mb-1">Sidebar Logo</small>
                        <div class="d-flex align-items-center gap-2">
                            <img t-if="state.hasLogo" class="t4_branding_preview"
                                t-attf-src="/web/image?model=res.company&amp;field=appbar_image&amp;id={{ state.companyId }}"/>
                            <span t-else="" class="text-muted small">No logo</span>
                            <label class="btn btn-sm btn-outline-secondary mb-0">
                                <i class="fa fa-upload me-1"/>Upload
                                <input type="file" class="d-none" accept="image/*"
                                    t-on-change="(ev) => this.onUploadImage('appbar_image', ev)"/>
                            </label>
                        </div>
                    </div>

                    <!-- Background Image -->
                    <div class="mb-3">
                        <small class="text-muted d-block mb-1">Apps Menu Background</small>
                        <div class="d-flex align-items-center gap-2">
                            <img t-if="state.hasBackground" class="t4_branding_preview"
                                t-attf-src="/web/image?model=res.company&amp;field=background_image&amp;id={{ state.companyId }}"/>
                            <span t-else="" class="text-muted small">No image</span>
                            <label class="btn btn-sm btn-outline-secondary mb-0">
                                <i class="fa fa-upload me-1"/>Upload
                                <input type="file" class="d-none" accept="image/*"
                                    t-on-change="(ev) => this.onUploadImage('background_image', ev)"/>
                            </label>
                        </div>
                    </div>

                    <!-- Favicon -->
                    <div>
                        <small class="text-muted d-block mb-1">Favicon</small>
                        <div class="d-flex align-items-center gap-2">
                            <img t-if="state.hasFavicon" class="t4_favicon_preview"
                                t-attf-src="/web/image?model=res.company&amp;field=favicon&amp;id={{ state.companyId }}"/>
                            <span t-else="" class="text-muted small">Default</span>
                            <label class="btn btn-sm btn-outline-secondary mb-0">
                                <i class="fa fa-upload me-1"/>Upload
                                <input type="file" class="d-none" accept="image/*"
                                    t-on-change="(ev) => this.onUploadImage('favicon', ev)"/>
                            </label>
                        </div>
                    </div>
                </div>

            </div>
        </div>
        </t>
    </t>

</templates>
