<?xml version="1.0" encoding="UTF-8" ?>

<templates xml:space="preserve">

    <t t-name="t4_theme.ThemeSystray">
        <!-- Systray Button -->
        <div class="o_theme_systray">
            <button class="btn o_theme_systray_btn" t-on-click="togglePanel" title="Cài đặt giao diện">
                <i class="fa fa-lg fa-paint-brush"/>
            </button>
        </div>

        <!-- Portal to body -->
        <t t-portal="'body'">
            <!-- Right Sidebar Panel (no backdrop, page stays interactive) -->
            <div t-ref="panel" class="t4_theme_panel" t-att-class="{ open: state.open }">

            <!-- Header -->
            <div class="t4_theme_panel_header">
                <h6 class="mb-0 fw-bold">
                    <i class="fa fa-paint-brush me-2"/>Cài đặt giao diện
                </h6>
                <button class="btn btn-sm btn-close" t-on-click="closePanel"/>
            </div>

            <div t-if="isSuperAdmin or isOnHomeMenu" class="px-3 py-2 border-bottom">
                <div class="d-flex gap-2">
                    <button t-if="isSuperAdmin" class="btn btn-sm btn-outline-primary flex-fill"
                        t-on-click="onOpenThemeSettings">
                        <i class="fa fa-paint-brush me-1"/>Sửa CSS
                    </button>
                    <button t-if="isOnHomeMenu" class="btn btn-sm flex-fill"
                        t-att-class="isHomeEditMode ? 'btn-primary' : 'btn-outline-secondary'"
                        t-on-click="onToggleHomeEdit">
                        <i t-att-class="isHomeEditMode ? 'fa fa-check me-1' : 'fa fa-th me-1'"/>
                        <t t-if="isHomeEditMode">Xong</t>
                        <t t-else="">Sửa Home Menu</t>
                    </button>
                </div>
            </div>

            <div class="t4_theme_panel_body">

                <!-- ====== Dark Mode ====== -->
                <div class="t4_section">
                    <div class="d-flex align-items-center justify-content-between">
                        <span class="t4_section_label">
                            <i class="fa fa-moon-o me-2"/>Dark Mode
                        </span>
                        <div class="form-check form-switch mb-0">
                            <input type="checkbox" class="form-check-input"
                                t-att-checked="state.darkMode"
                                t-on-change="onToggleDarkMode"/>
                        </div>
                    </div>
                </div>

                <!-- ====== Personal Mode Toggle ====== -->
                <div class="t4_section">
                    <div class="d-flex align-items-center justify-content-between">
                        <span class="t4_section_label">
                            <i class="fa fa-user me-2"/>Dùng màu cá nhân
                        </span>
                        <div class="form-check form-switch mb-0">
                            <input type="checkbox" class="form-check-input"
                                t-att-checked="state.personalMode"
                                t-on-change="onTogglePersonalMode"/>
                        </div>
                    </div>
                    <small class="text-muted d-block mt-1">
                        <t t-if="state.personalMode">
                            Đang dùng bộ màu/font riêng của bạn. Lưu sẽ ghi vào tài khoản cá nhân.
                        </t>
                        <t t-elif="canEditCompanyTheme">
                            Đang dùng theme công ty. Lưu sẽ ghi cho cả công ty.
                        </t>
                        <t t-else="">
                            Bật để tùy chỉnh màu/font riêng. Khi tắt, hệ thống dùng theme công ty.
                        </t>
                    </small>
                    <button t-if="state.personalMode" class="btn btn-sm btn-outline-secondary w-100 mt-2"
                        t-on-click="onClearPersonalColors">
                        <i class="fa fa-undo me-1"/>Bỏ màu cá nhân, dùng màu công ty
                    </button>
                </div>

                <!-- ====== Theme Presets ====== -->
                <div t-if="canEditColors" class="t4_section">
                    <span class="t4_section_label d-block mb-2">
                        <i class="fa fa-swatchbook me-2"/>Giao diện có sẵn
                    </span>
                    <div class="t4_ts_preset_grid">
                        <t t-foreach="presets" t-as="preset" t-key="preset.id">
                            <div class="t4_ts_preset_item" t-on-click="() => this.onSelectPreset(preset)">
                                <div t-attf-class="t4_ts_preset_circle {{ state.currentPreset === preset.id ? 't4_ts_preset_active' : '' }}"
                                     t-att-style="'background-color:' + preset.preview_color">
                                    <i t-if="state.currentPreset === preset.id" class="fa fa-check"/>
                                </div>
                                <span class="t4_ts_preset_name" t-esc="preset.name"/>
                                <button t-if="!preset.is_default"
                                        class="t4_ts_preset_delete"
                                        t-on-click.stop="() => this.onDeletePreset(preset.id)"
                                        title="Delete preset">
                                    <i class="fa fa-times"/>
                                </button>
                            </div>
                        </t>
                        <!-- Create new preset -->
                        <div class="t4_ts_preset_item t4_ts_preset_add" t-on-click="onShowCreatePreset">
                            <div class="t4_ts_preset_circle t4_ts_preset_circle_add">
                                <i class="fa fa-plus"/>
                            </div>
                            <span class="t4_ts_preset_name">Tạo mới</span>
                        </div>
                    </div>

                    <!-- Create preset form (inline) -->
                    <div t-if="state.showCreatePreset" class="t4_ts_create_preset">
                        <input type="text" class="form-control form-control-sm"
                               placeholder="Tên giao diện..."
                               t-att-value="state.newPresetName"
                               t-on-input="onNewPresetNameInput"
                               t-on-keydown="(ev) => ev.key === 'Enter' and this.onSaveNewPreset()"/>
                        <div class="t4_ts_create_preset_actions">
                            <button class="btn btn-sm btn-primary" t-on-click="onSaveNewPreset">Lưu</button>
                            <button class="btn btn-sm btn-light" t-on-click="onCancelCreatePreset">Hủy</button>
                        </div>
                    </div>

                    <!-- Import / Export -->
                    <div class="t4_ts_import_export">
                        <button class="btn btn-sm btn-outline-secondary" t-on-click="onExportTheme">
                            <i class="fa fa-download me-1"/>Export
                        </button>
                        <button class="btn btn-sm btn-outline-secondary" t-on-click="onImportThemeClick"
                                t-att-disabled="state.importing">
                            <i t-attf-class="fa {{ state.importing ? 'fa-spinner fa-spin' : 'fa-upload' }} me-1"/>Import
                        </button>
                    </div>
                </div>

                <!-- ====== Typography ====== -->
                <div t-if="canEditColors" class="t4_section">
                    <span class="t4_section_label d-block mb-2">
                        <i class="fa fa-font me-2"/>Typography
                    </span>

                    <!-- Font Family - Custom searchable dropdown -->
                    <div class="mb-3">
                        <small class="text-muted d-block mb-1">Font Family</small>
                        <div class="t4_font_dropdown">
                            <button class="t4_font_dropdown_toggle"
                                t-att-style="selectedFontStyle"
                                t-on-click="toggleFontDropdown">
                                <span t-out="selectedFontLabel"/>
                                <i class="fa fa-chevron-down"/>
                            </button>
                            <div t-if="state.fontDropdownOpen" class="t4_font_dropdown_menu">
                                <input type="text" class="t4_font_search"
                                    placeholder="Tìm font..."
                                    t-on-input="(ev) => this.state.fontSearch = ev.target.value"
                                    t-ref="fontSearch"/>
                                <div class="t4_font_list">
                                    <t t-foreach="fontOptions" t-as="opt" t-key="opt.key">
                                        <t t-if="!state.fontSearch || opt.label.toLowerCase().includes((state.fontSearch || '').toLowerCase())">
                                            <button class="t4_font_option"
                                                t-attf-class="{{ state.fontFamily === opt.key ? 'active' : '' }}"
                                                t-att-style="this.fontStyle(opt.key)"
                                                t-on-click="() => this.onSelectFont(opt.key)">
                                                <span class="t4_font_option_label" t-out="opt.label"/>
                                                <span class="t4_font_option_preview" t-att-style="this.fontStyle(opt.key)">
                                                    Aa Bb Cc 123
                                                </span>
                                                <i t-if="state.fontFamily === opt.key" class="fa fa-check"/>
                                            </button>
                                        </t>
                                    </t>
                                </div>
                            </div>
                        </div>
                    </div>

                </div>

                <!-- ====== Layout Options ====== -->
                <div class="t4_section">
                    <span class="t4_section_label d-block mb-2">
                        <i class="fa fa-columns me-2"/>Bố cục
                    </span>

                    <!-- Sidebar -->
                    <div class="mb-2">
                        <small class="text-muted d-block mb-1">Thanh bên</small>
                        <div class="btn-group w-100" role="group">
                            <t t-foreach="sidebarOptions" t-as="opt" t-key="opt.key">
                                <button type="button" class="btn btn-sm"
                                    t-attf-class="{{ state.sidebarType === opt.key ? 'btn-primary' : 'btn-outline-secondary' }}"
                                    t-on-click="() => this.onSelectSidebar(opt.key)">
                                    <i t-attf-class="fa {{ opt.icon }} me-1"/>
                                    <t t-out="opt.label"/>
                                </button>
                            </t>
                        </div>
                    </div>

                    <!-- Chatter -->
                    <div class="mb-2">
                        <small class="text-muted d-block mb-1">Chatter</small>
                        <div class="btn-group w-100" role="group">
                            <t t-foreach="chatterOptions" t-as="opt" t-key="opt.key">
                                <button type="button" class="btn btn-sm"
                                    t-attf-class="{{ state.chatterPosition === opt.key ? 'btn-primary' : 'btn-outline-secondary' }}"
                                    t-on-click="() => this.onSelectChatter(opt.key)">
                                    <t t-out="opt.label"/>
                                </button>
                            </t>
                        </div>
                    </div>

                    <!-- Dialog -->
                    <div class="mb-2">
                        <small class="text-muted d-block mb-1">Dialog</small>
                        <div class="btn-group w-100" role="group">
                            <t t-foreach="dialogOptions" t-as="opt" t-key="opt.key">
                                <button type="button" class="btn btn-sm"
                                    t-attf-class="{{ state.dialogSize === opt.key ? 'btn-primary' : 'btn-outline-secondary' }}"
                                    t-on-click="() => this.onSelectDialog(opt.key)">
                                    <t t-out="opt.label"/>
                                </button>
                            </t>
                        </div>
                    </div>

                    <!-- Home Menu Overlay -->
                    <div t-if="canEditCompanyTheme">
                        <div class="d-flex align-items-center justify-content-between">
                            <small class="text-muted">
                                Home Menu Overlay
                                <i class="fa fa-info-circle ms-1" style="font-size:11px; cursor:help;"
                                    title="Bật/tắt màn hình Home Menu toàn trang khi bấm ESC"/>
                            </small>
                            <div class="form-check form-switch mb-0">
                                <input type="checkbox" class="form-check-input"
                                    t-att-checked="state.homeMenuOverlay"
                                    t-on-change="onToggleHomeMenuOverlay"/>
                            </div>
                        </div>
                    </div>

                    <!-- Icon Shape -->
                    <div t-if="canEditCompanyTheme" class="mt-2">
                        <small class="text-muted d-block mb-1">Hình dạng icon ứng dụng</small>
                        <div class="btn-group w-100 flex-wrap" role="group">
                            <t t-foreach="iconShapeOptions" t-as="opt" t-key="opt.key">
                                <button type="button" class="btn btn-sm"
                                    t-attf-class="{{ state.iconShape === opt.key ? 'btn-primary' : 'btn-outline-secondary' }}"
                                    t-on-click="() => this.onSelectIconShape(opt.key)">
                                    <t t-out="opt.label"/>
                                </button>
                            </t>
                        </div>
                    </div>
                </div>

                <!-- ====== Brand Colors ====== -->
                <div t-if="canEditColors" class="t4_section">
                    <span class="t4_section_label d-block mb-2">
                        <i class="fa fa-tint me-2"/>Màu thương hiệu
                    </span>
                    <div class="t4_color_row">
                        <label>Thương hiệu</label>
                        <input type="color" t-att-value="state.colorBrand"
                            t-on-input="(ev) => this.onColorChange('colorBrand', ev)"/>
                    </div>
                    <div class="t4_color_row">
                        <label>Chính</label>
                        <input type="color" t-att-value="state.colorPrimary"
                            t-on-input="(ev) => this.onColorChange('colorPrimary', ev)"/>
                    </div>
                </div>

                <!-- ====== Context Colors ====== -->
                <div t-if="canEditColors" class="t4_section">
                    <span class="t4_section_label d-block mb-2">
                        <i class="fa fa-circle-o me-2"/>Màu ngữ cảnh
                    </span>
                    <div class="t4_color_row">
                        <label>Success</label>
                        <input type="color" t-att-value="state.colorSuccess"
                            t-on-input="(ev) => this.onColorChange('colorSuccess', ev)"/>
                    </div>
                    <div class="t4_color_row">
                        <label>Info</label>
                        <input type="color" t-att-value="state.colorInfo"
                            t-on-input="(ev) => this.onColorChange('colorInfo', ev)"/>
                    </div>
                    <div class="t4_color_row">
                        <label>Warning</label>
                        <input type="color" t-att-value="state.colorWarning"
                            t-on-input="(ev) => this.onColorChange('colorWarning', ev)"/>
                    </div>
                    <div class="t4_color_row">
                        <label>Danger</label>
                        <input type="color" t-att-value="state.colorDanger"
                            t-on-input="(ev) => this.onColorChange('colorDanger', ev)"/>
                    </div>
                </div>

                <!-- ====== Sidebar Colors ====== -->
                <div t-if="canEditColors" class="t4_section">
                    <span class="t4_section_label d-block mb-2">
                        <i class="fa fa-bars me-2"/>Màu thanh bên
                    </span>
                    <div class="t4_color_row">
                        <label>Nền</label>
                        <input type="color" t-att-value="state.colorAppbarBg"
                            t-on-input="(ev) => this.onColorChange('colorAppbarBg', ev)"/>
                    </div>
                    <div class="t4_color_row">
                        <label>Chữ</label>
                        <input type="color" t-att-value="state.colorAppbarText"
                            t-on-input="(ev) => this.onColorChange('colorAppbarText', ev)"/>
                    </div>
                    <div class="t4_color_row">
                        <label>Đang chọn</label>
                        <input type="color" t-att-value="state.colorAppbarActive"
                            t-on-input="(ev) => this.onColorChange('colorAppbarActive', ev)"/>
                    </div>
                    <div class="t4_color_row">
                        <label>Chữ menu</label>
                        <input type="color" t-att-value="state.colorAppsmenuText"
                            t-on-input="(ev) => this.onColorChange('colorAppsmenuText', ev)"/>
                    </div>
                </div>

                <!-- ====== Branding ====== -->
                <div t-if="canEditCompanyTheme" class="t4_section">
                    <span class="t4_section_label d-block mb-2">
                        <i class="fa fa-building-o me-2"/>Thương hiệu
                    </span>

                    <!-- URL Prefix -->
                    <div class="mb-3">
                        <div class="d-flex align-items-center gap-1 mb-1">
                            <small class="text-muted">URL Prefix</small>
                            <i class="fa fa-info-circle text-muted" style="font-size:12px; cursor:help;"
                                title="Thay /odoo/ trong URL. VD: nhập 'app' → /app/settings. Để trống = /odoo/ mặc định. Cần reload sau khi thay đổi."/>
                        </div>
                        <input type="text" class="form-control form-control-sm"
                            t-att-value="state.urlPrefix"
                            t-on-change="onChangeUrlPrefix"
                            placeholder="app"/>
                    </div>

                    <!-- Brand Name -->
                    <div class="mb-3">
                        <div class="d-flex align-items-center gap-1 mb-1">
                            <small class="text-muted">Tên thương hiệu</small>
                        </div>
                        <input type="text" class="form-control form-control-sm"
                            t-att-value="state.brandName"
                            t-on-change="onChangeBrandName"
                            placeholder="My Company"/>
                    </div>

                    <!-- Browser Title -->
                    <div class="mb-3">
                        <div class="d-flex align-items-center gap-1 mb-1">
                            <small class="text-muted">Tiêu đề trình duyệt</small>
                        </div>
                        <input type="text" class="form-control form-control-sm"
                            t-att-value="state.webTitle"
                            t-on-change="onChangeWebTitle"
                            placeholder="My ERP"/>
                    </div>

                    <!-- Logo -->
                    <div class="mb-3">
                        <small class="text-muted d-block mb-1">Logo thanh bên</small>
                        <div class="d-flex align-items-center gap-2">
                            <img t-if="state.hasLogo" class="t4_branding_preview"
                                t-attf-src="/web/image?model=res.company&amp;field=appbar_image&amp;id={{ state.companyId }}"/>
                            <span t-else="" class="text-muted small">Chưa có logo</span>
                            <label class="btn btn-sm btn-outline-secondary mb-0">
                                <i class="fa fa-upload me-1"/>Tải lên
                                <input type="file" class="d-none" accept="image/*"
                                    t-on-change="(ev) => this.onUploadImage('appbar_image', ev)"/>
                            </label>
                            <button t-if="state.hasLogo"
                                class="btn btn-sm btn-outline-danger mb-0"
                                t-on-click="() => this.onRemoveImage('appbar_image')">
                                <i class="fa fa-trash"/>
                            </button>
                        </div>
                    </div>

                    <!-- Background Image -->
                    <div class="mb-3">
                        <small class="text-muted d-block mb-1">Ảnh nền menu ứng dụng</small>
                        <div class="d-flex align-items-center gap-2">
                            <img t-if="state.hasBackground" class="t4_branding_preview"
                                t-attf-src="/web/image?model=res.company&amp;field=background_image&amp;id={{ state.companyId }}"/>
                            <span t-else="" class="text-muted small">Chưa có ảnh</span>
                            <label class="btn btn-sm btn-outline-secondary mb-0">
                                <i class="fa fa-upload me-1"/>Tải lên
                                <input type="file" class="d-none" accept="image/*"
                                    t-on-change="(ev) => this.onUploadImage('background_image', ev)"/>
                            </label>
                            <button t-if="state.hasBackground"
                                class="btn btn-sm btn-outline-danger mb-0"
                                t-on-click="() => this.onRemoveImage('background_image')">
                                <i class="fa fa-trash"/>
                            </button>
                        </div>
                    </div>

                    <!-- Favicon -->
                    <div>
                        <small class="text-muted d-block mb-1">Favicon</small>
                        <div class="d-flex align-items-center gap-2">
                            <img t-if="state.hasFavicon" class="t4_favicon_preview"
                                t-attf-src="/web/image?model=res.company&amp;field=favicon&amp;id={{ state.companyId }}"/>
                            <span t-else="" class="text-muted small">Mặc định</span>
                            <label class="btn btn-sm btn-outline-secondary mb-0">
                                <i class="fa fa-upload me-1"/>Tải lên
                                <input type="file" class="d-none" accept="image/*"
                                    t-on-change="(ev) => this.onUploadImage('favicon', ev)"/>
                            </label>
                            <button t-if="state.hasFavicon"
                                class="btn btn-sm btn-outline-danger mb-0"
                                t-on-click="() => this.onRemoveImage('favicon')">
                                <i class="fa fa-trash"/>
                            </button>
                        </div>
                    </div>
                </div>

                <!-- ====== Reset to Odoo ====== -->
                <div t-if="canEditCompanyTheme" class="t4_section">
                    <button class="btn btn-sm btn-outline-danger w-100"
                        t-on-click="onResetToOdoo">
                        <i class="fa fa-refresh me-1"/>Đặt lại mặc định Odoo
                    </button>
                </div>

            </div>

            <!-- ====== Sticky Footer: Save / Reset ====== -->
            <div class="t4_theme_panel_footer" t-att-class="{ visible: state.dirty }">
                <button class="btn btn-sm btn-outline-secondary flex-fill"
                    t-att-disabled="state.saving"
                    t-on-click="onClickReset">
                    <i class="fa fa-undo me-1"/>Đặt lại
                </button>
                <button class="btn btn-sm btn-primary flex-fill"
                    t-att-disabled="state.saving"
                    t-on-click="onClickSave">
                    <i t-if="state.saving" class="fa fa-spinner fa-spin me-1"/>
                    <i t-else="" class="fa fa-check me-1"/>
                    Lưu
                </button>
            </div>

        </div>
        </t>
    </t>

</templates>
