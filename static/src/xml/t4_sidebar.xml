<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <!-- ================================================================
         T4 Sidebar — Persistent vertical navigation (OMUX style)
         No submenu here — submenus stay in the top navbar.
         ================================================================ -->
    <t t-name="t4_theme.Sidebar">
        <aside class="t4_sidebar d-print-none"
               t-att-class="{'t4_sidebar--collapsed': state.collapsed, 't4_sidebar--resizing': state.resizing}"
               t-att-style="sidebarStyle">

            <!-- APPS header -->
            <div class="t4_sidebar__apps_header" t-if="!state.collapsed">
                <span>APPS</span>
            </div>

            <!-- App list -->
            <div class="t4_sidebar__apps">
                <t t-foreach="apps" t-as="app" t-key="app.id">
                    <div t-att-class="{'t4_sidebar__app': true, 't4_sidebar__app--active': isActiveApp(app)}"
                         t-on-click="() => this.onAppClick(app)"
                         t-att-title="app.name">
                        <!-- Active blob indicator (OMUX style) -->
                        <span class="t4_sidebar__blob" t-if="isActiveApp(app)"/>
                        <!-- App icon -->
                        <div class="t4_sidebar__app_icon"
                             t-att-style="getAppIconBg(app) ? ('background-color: ' + getAppIconBg(app)) : ''">
                            <img t-if="getAppIcon(app)"
                                 t-att-src="getAppIcon(app)"
                                 class="t4_sidebar__app_img"
                                 t-att-alt="app.name"/>
                            <span t-else=""
                                  t-att-class="getAppIconClass(app)"/>
                        </div>
                        <!-- App name (hidden when collapsed) -->
                        <span class="t4_sidebar__app_name" t-if="!state.collapsed">
                            <t t-esc="app.name"/>
                        </span>
                    </div>
                </t>
            </div>

            <!-- Bookmarks (pinned) -->
            <div class="t4_sidebar__section" t-if="!state.collapsed and pinnedBookmarks.length">
                <div class="t4_sidebar__section_header">
                    <span>BOOKMARKS</span>
                </div>
                <t t-foreach="pinnedBookmarks" t-as="bm" t-key="bm.actionId">
                    <div class="t4_sidebar__recent_item"
                         t-on-click="() => this.onBookmarkClick(bm)">
                        <i class="fa fa-bookmark t4_sidebar__recent_icon" style="color: var(--t4-accent)"/>
                        <div class="t4_sidebar__recent_text">
                            <span class="t4_sidebar__recent_name" t-esc="bm.name"/>
                        </div>
                        <button class="btn btn-sm border-0 p-0 ms-auto"
                                t-on-click.stop="() => this.onBookmarkRemove(bm.actionId)"
                                title="Remove">
                            <i class="fa fa-times small text-muted"/>
                        </button>
                    </div>
                </t>
            </div>

            <!-- Recent Items (OMUX style) -->
            <div class="t4_sidebar__section" t-if="!state.collapsed and state.recentItems.length">
                <div class="t4_sidebar__section_header">
                    <span>RECENTS</span>
                    <span class="badge bg-secondary ms-auto" t-esc="state.recentItems.length"/>
                    <button class="btn btn-sm border-0 p-0 ms-1"
                            t-on-click="clearRecents" title="Clear">
                        <i class="fa fa-times small text-muted"/>
                    </button>
                </div>
                <t t-foreach="state.recentItems.slice(0, 10)" t-as="item" t-key="item.id">
                    <div class="t4_sidebar__recent_item"
                         t-on-click="() => this.onRecentClick(item)">
                        <i class="fa fa-circle t4_sidebar__recent_dot"/>
                        <div class="t4_sidebar__recent_text">
                            <span class="t4_sidebar__recent_name" t-esc="item.name"/>
                            <span class="t4_sidebar__recent_app" t-if="item.appName" t-esc="item.appName"/>
                        </div>
                    </div>
                </t>
            </div>

            <!-- Collapse toggle -->
            <div class="t4_sidebar__footer">
                <button class="t4_sidebar__toggle btn btn-sm"
                        t-on-click="toggleCollapse"
                        t-att-title="state.collapsed ? 'Expand' : 'Collapse'">
                    <i t-att-class="state.collapsed ? 'fa fa-chevron-right' : 'fa fa-chevron-left'"/>
                </button>
            </div>

            <!-- Resize handle -->
            <div class="t4_sidebar__resize_handle"
                 t-if="!state.collapsed"
                 t-on-mousedown="onResizeStart"/>
        </aside>
    </t>

    <!-- Patch WebClient template to include sidebar -->
    <t t-name="t4_theme.WebClient" t-inherit="web.WebClient" t-inherit-mode="extension">
        <xpath expr="//ActionContainer" position="before">
            <T4Sidebar/>
        </xpath>
    </t>

</templates>
