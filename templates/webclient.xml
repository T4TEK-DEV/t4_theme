<?xml version="1.0" encoding="UTF-8"?>

<odoo>

    <!-- AppsBar: Add sidebar class to body -->
    <template id="webclient_bootstrap" name="Web Client" inherit_id="web.webclient_bootstrap">
        <xpath expr="//t[@t-set='body_classname']" position="after">
            <t t-set="body_sidebar_classname" t-value="'mk_sidebar_type_' + request.env.user.sidebar_type or 'large'"/>
            <t t-set="body_classname" t-value="'%s %s' % (body_classname, body_sidebar_classname)"/>
        </xpath>
    </template>

    <!-- Colors: Override theme-color meta -->
    <template id="webclient_bootstrap_colors" inherit_id="web.webclient_bootstrap">
        <xpath expr="//meta[@name='theme-color']" position="replace">
            <meta name="theme-color" content="#242733"/>
        </xpath>
    </template>

</odoo>
