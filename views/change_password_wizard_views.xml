<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="change_password_wizard_form" model="ir.ui.view">
        <field name="name">t4.change.password.wizard.form</field>
        <field name="model">t4.change.password.wizard</field>
        <field name="arch" type="xml">
            <form string="Thay đổi mật khẩu">
                <group>
                    <field class="o_field_highlight col-10 col-md-6 px-0"
                           string="Mật khẩu hiện tại"
                           name="current_password"
                           autocomplete="current-password"
                           required="1"
                           password="True"
                           placeholder="************"/>
                    <field name="new_password"
                           string="Mật khẩu mới"
                           password="True"
                           required="1"/>
                    <field name="confirm_password"
                           string="Xác nhận mật khẩu mới"
                           password="True"
                           required="1"/>
                </group>
                <footer>
                    <button string="Đổi mật khẩu"
                            name="change_password"
                            type="object"
                            class="btn-primary"
                            data-hotkey="q"/>
                    <button string="Hủy"
                            class="btn-secondary"
                            special="cancel"
                            data-hotkey="x"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
