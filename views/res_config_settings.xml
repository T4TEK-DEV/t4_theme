<?xml version="1.0" encoding="UTF-8"?>

<odoo>

	<record id="view_res_config_settings_theme_form" model="ir.ui.view">
	    <field name="name">res.config.settings.form.theme</field>
	    <field name="model">res.config.settings</field>
	    <field name="inherit_id" ref="base_setup.res_config_settings_view_form"/>
	    <field name="arch" type="xml">
	    	<xpath expr="//block[@id='user_default_rights']" position="before">
	    		<block title="Giao diện Backend" id="theme_settings">

	    			<!-- Theme Preset -->
	    			<setting
	    				string="Giao diện có sẵn"
	    				company_dependent="1"
	    				help="Chọn bộ màu có sẵn cho công ty hiện tại"
	    			>
	    				<div class="w-50 row">
	    					<field name="theme_preset" class="w-75"/>
	    					<button
	    						name="action_apply_theme_preset"
	    						type="object"
	    						string="Áp dụng"
	    						class="btn-primary ms-2"
	    						icon="fa-paint-brush"
	    					/>
	    				</div>
	    			</setting>

	    			<!-- Brand & UI Colors (per-company) -->
	    			<setting
	    				string="Màu giao diện"
	    				company_dependent="1"
	    				help="Tùy chỉnh màu thương hiệu và giao diện cho công ty hiện tại"
	    			>
                     	<div class="w-50 row">
                            <label for="theme_color_brand" string="Thương hiệu" class="d-block w-75 py-2"/>
                            <field name="theme_color_brand" class="d-block w-25 p-0 m-0" widget="color"/>
                        </div>
                     	<div class="w-50 row">
                            <label for="theme_color_primary" string="Màu chính" class="d-block w-75 py-2"/>
                            <field name="theme_color_primary" class="d-block w-25 p-0 m-0" widget="color"/>
                        </div>
                     	<div class="w-50 row">
                            <label for="theme_color_appsmenu_text" string="Chữ menu" class="d-block w-75 py-2"/>
                            <field name="theme_color_appsmenu_text" class="d-block w-25 p-0 m-0" widget="color"/>
                        </div>
                     	<div class="w-50 row">
                            <label for="theme_color_appbar_text" string="Chữ thanh bên" class="d-block w-75 py-2"/>
                            <field name="theme_color_appbar_text" class="d-block w-25 p-0 m-0" widget="color"/>
                        </div>
                     	<div class="w-50 row">
                            <label for="theme_color_appbar_active" string="Thanh bên đang chọn" class="d-block w-75 py-2"/>
                            <field name="theme_color_appbar_active" class="d-block w-25 p-0 m-0" widget="color"/>
                        </div>
                     	<div class="w-50 row">
                            <label for="theme_color_appbar_background" string="Nền thanh bên" class="d-block w-75 py-2"/>
                            <field name="theme_color_appbar_background" class="d-block w-25 p-0 m-0" widget="color"/>
                        </div>
                    </setting>

                    <!-- Context Colors (per-company) -->
	    			<setting
	    				string="Màu ngữ cảnh"
	    				company_dependent="1"
	    				help="Tùy chỉnh màu ngữ cảnh cho công ty hiện tại"
	    			>
                     	<div class="w-50 row">
                            <label for="theme_color_info" string="Info" class="d-block w-75 py-2"/>
                            <field name="theme_color_info" class="d-block w-25 p-0 m-0" widget="color"/>
                        </div>
                     	<div class="w-50 row">
                            <label for="theme_color_success" string="Success" class="d-block w-75 py-2"/>
                            <field name="theme_color_success" class="d-block w-25 p-0 m-0" widget="color"/>
                        </div>
                     	<div class="w-50 row">
                            <label for="theme_color_warning" string="Warning" class="d-block w-75 py-2"/>
                            <field name="theme_color_warning" class="d-block w-25 p-0 m-0" widget="color"/>
                        </div>
                     	<div class="w-50 row">
                            <label for="theme_color_danger" string="Danger" class="d-block w-75 py-2"/>
                            <field name="theme_color_danger" class="d-block w-25 p-0 m-0" widget="color"/>
                        </div>
                        <button
                            name="action_reset_theme_colors"
                            icon="fa-refresh"
                            type="object"
                            string="Đặt lại màu mặc định"
                            class="btn-link"
                        />
                    </setting>

                    <!-- Background Image (per-company) -->
	    			<setting
	    				string="Ảnh nền"
	    				company_dependent="1"
	    				help="Đặt ảnh nền cho menu ứng dụng"
	    			>
	    				<field name="theme_background_image" widget="image" class="ml-4 w-75"/>
                    </setting>

                    <!-- Branding & Debranding (per-company) -->
                    <setting
                    	string="Thương hiệu"
                    	company_dependent="1"
                    	help="Thay thế thương hiệu Odoo bằng của bạn trên toàn hệ thống"
                    >
		    			<div class="w-50 row">
	                        <label for="t4_brand_name" string="Tên thương hiệu" class="o_light_label mb-1"/>
	                        <field name="t4_brand_name" class="w-75" placeholder="My Company"/>
	                        <div class="text-muted small mt-1 mb-2">Thay thế "Odoo" trên trang đăng nhập, email, hộp thoại, báo cáo, v.v.</div>
	                        <div class="w-100 mt-1"/>
	                        <label for="t4_web_title" string="Tiêu đề trình duyệt" class="o_light_label mb-1"/>
	                        <field name="t4_web_title" class="w-75" placeholder="My ERP"/>
	                        <div class="w-100 mt-1"/>
	                        <label for="t4_url_prefix" string="URL Prefix" class="o_light_label mb-1"/>
	                        <field name="t4_url_prefix" class="w-75" placeholder="app"/>
	                        <div class="text-muted small mt-1 mb-2">Thay /odoo/ trong URL. VD: "app" → /app/settings. Để trống giữ /odoo/ mặc định.</div>
	                        <div class="w-100 mt-1"/>
	                    	<label for="appbar_image" string="Logo" class="o_light_label mb-1"/>
	                        <field name="appbar_image" widget="image" class="ml-4 oe_avatar"/>
	                        <div class="w-100 mt-1"/>
	                    	<label for="theme_favicon" string="Favicon" class="o_light_label mb-1"/>
	                        <field name="theme_favicon" widget="image" class="ml-4 oe_avatar"/>
	                    </div>
	                </setting>

	    		</block>
	    	</xpath>
	    </field>
	</record>

</odoo>
