<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Form View -->
    <record id="t4_theme_config_form" model="ir.ui.view">
        <field name="name">t4.theme.config.form</field>
        <field name="model">t4.theme.config</field>
        <field name="arch" type="xml">
            <form string="Theme Configuration">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <field name="is_active" widget="boolean_favorite"
                               nolabel="1"/>
                    </div>
                    <group>
                        <group string="General">
                            <field name="company_id"
                                   options="{'no_create': True}"
                                   groups="base.group_multi_company"/>
                            <field name="color_scheme" widget="radio"/>
                            <field name="preset_id"
                                   options="{'no_create': True}"/>
                        </group>
                        <group string="Appearance">
                            <field name="font_family"/>
                            <field name="sidebar_style"/>
                        </group>
                    </group>
                    <group string="Colors">
                        <group>
                            <field name="primary_color" widget="color"/>
                            <field name="secondary_color" widget="color"/>
                            <field name="accent_color" widget="color"/>
                        </group>
                        <group>
                            <field name="dark_mode_logo" widget="image"
                                   options="{'size': [200, 100]}"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Advanced" name="advanced">
                            <group>
                                <field name="custom_css_vars"
                                       placeholder='{"--t4-border-radius": "8px"}'/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- List View -->
    <record id="t4_theme_config_list" model="ir.ui.view">
        <field name="name">t4.theme.config.list</field>
        <field name="model">t4.theme.config</field>
        <field name="arch" type="xml">
            <list string="Theme Configurations">
                <field name="company_id"/>
                <field name="color_scheme"/>
                <field name="primary_color" widget="color"/>
                <field name="font_family"/>
                <field name="sidebar_style"/>
                <field name="is_active"/>
            </list>
        </field>
    </record>

    <!-- Action -->
    <record id="action_t4_theme_config" model="ir.actions.act_window">
        <field name="name">Theme Configurations</field>
        <field name="res_model">t4.theme.config</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a theme configuration
            </p>
            <p>Configure colors, dark mode, fonts and sidebar per company.</p>
        </field>
    </record>

    <!-- Preset List View -->
    <record id="t4_theme_preset_list" model="ir.ui.view">
        <field name="name">t4.theme.preset.list</field>
        <field name="model">t4.theme.preset</field>
        <field name="arch" type="xml">
            <list string="Theme Presets">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="color_scheme"/>
                <field name="primary_color" widget="color"/>
                <field name="accent_color" widget="color"/>
                <field name="font_family"/>
                <field name="is_system"/>
            </list>
        </field>
    </record>

    <!-- Preset Form View -->
    <record id="t4_theme_preset_form" model="ir.ui.view">
        <field name="name">t4.theme.preset.form</field>
        <field name="model">t4.theme.preset</field>
        <field name="arch" type="xml">
            <form string="Theme Preset">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="sequence"/>
                            <field name="is_system" readonly="1"/>
                        </group>
                        <group>
                            <field name="color_scheme" widget="radio"/>
                            <field name="font_family"/>
                            <field name="sidebar_style"/>
                        </group>
                    </group>
                    <group string="Colors">
                        <group>
                            <field name="primary_color" widget="color"/>
                            <field name="secondary_color" widget="color"/>
                            <field name="accent_color" widget="color"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Export / Import" name="json">
                            <group>
                                <field name="json_data"/>
                            </group>
                        </page>
                        <page string="Custom CSS" name="custom_css">
                            <group>
                                <field name="custom_css_vars"
                                       placeholder='{"--t4-border-radius": "8px"}'/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Preset Action -->
    <record id="action_t4_theme_preset" model="ir.actions.act_window">
        <field name="name">Theme Presets</field>
        <field name="res_model">t4.theme.preset</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
