<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================ -->
    <!-- KANBAN VIEW — Theme Demo -->
    <!-- ============================================================ -->
    <record id="t4_theme_demo_view_kanban" model="ir.ui.view">
        <field name="name">t4.theme.demo.kanban</field>
        <field name="model">t4.theme.demo</field>
        <field name="arch" type="xml">
            <kanban default_group_by="stage" highlight_color="color">
                <field name="color"/>
                <progressbar field="stage" colors='{"draft": "default", "progress": "warning", "review": "info", "done": "success", "cancel": "danger"}'/>
                <templates>
                    <t t-name="card">
                        <widget name="web_ribbon" title="Done" bg_color="text-bg-success" invisible="stage != 'done'"/>
                        <div class="oe_kanban_details">
                            <div class="o_kanban_record_top mb-0">
                                <div class="o_kanban_record_headings">
                                    <strong class="o_kanban_record_title">
                                        <field name="name"/>
                                    </strong>
                                </div>
                                <div class="o_dropdown_kanban dropdown">
                                    <a role="button" class="dropdown-toggle o-no-caret btn" data-bs-toggle="dropdown" href="#" aria-label="Dropdown menu" title="Dropdown menu">
                                        <span class="fa fa-ellipsis-v"/>
                                    </a>
                                    <div class="dropdown-menu" role="menu">
                                        <a role="menuitem" type="edit" class="dropdown-item">Sửa</a>
                                        <a role="menuitem" type="delete" class="dropdown-item">Xóa</a>
                                    </div>
                                </div>
                            </div>
                            <div class="o_kanban_record_body">
                                <field name="description"/>
                            </div>
                            <div class="o_kanban_record_bottom">
                                <div class="oe_kanban_bottom_left">
                                    <field name="priority" widget="priority"/>
                                    <field name="tag_ids" widget="many2many_tags" options="{'color_field': 'color'}"/>
                                </div>
                                <div class="oe_kanban_bottom_right">
                                    <field name="amount" widget="monetary"/>
                                    <field name="user_id" widget="many2one_avatar_user"/>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- ============================================================ -->
    <!-- LIST VIEW — Theme Demo -->
    <!-- ============================================================ -->
    <record id="t4_theme_demo_view_list" model="ir.ui.view">
        <field name="name">t4.theme.demo.list</field>
        <field name="model">t4.theme.demo</field>
        <field name="arch" type="xml">
            <list default_order="sequence,id" multi_edit="1">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="stage" widget="badge" decoration-success="stage == 'done'" decoration-info="stage == 'review'" decoration-warning="stage == 'progress'" decoration-danger="stage == 'cancel'"/>
                <field name="priority" widget="priority"/>
                <field name="partner_id"/>
                <field name="user_id" widget="many2one_avatar_user"/>
                <field name="date_start"/>
                <field name="date_end"/>
                <field name="amount" sum="Total"/>
                <field name="progress" widget="progressbar"/>
                <field name="tag_ids" widget="many2many_tags" options="{'color_field': 'color'}"/>
            </list>
        </field>
    </record>

    <!-- ============================================================ -->
    <!-- FORM VIEW — Theme Demo -->
    <!-- ============================================================ -->
    <record id="t4_theme_demo_view_form" model="ir.ui.view">
        <field name="name">t4.theme.demo.form</field>
        <field name="model">t4.theme.demo</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <field name="stage" widget="statusbar" statusbar_visible="draft,progress,review,done"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button class="oe_stat_button" icon="fa-clock-o">
                            <div class="o_stat_info">
                                <span class="o_stat_value"><field name="amount"/></span>
                                <span class="o_stat_text">Số tiền</span>
                            </div>
                        </button>
                        <button class="oe_stat_button" icon="fa-tasks">
                            <div class="o_stat_info">
                                <span class="o_stat_value"><field name="progress"/>%</span>
                                <span class="o_stat_text">Tiến độ</span>
                            </div>
                        </button>
                    </div>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="Tiêu đề..."/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="partner_id"/>
                            <field name="user_id"/>
                            <field name="priority"/>
                        </group>
                        <group>
                            <field name="date_start"/>
                            <field name="date_end"/>
                            <field name="amount"/>
                            <field name="progress" widget="progressbar"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Mô tả" name="description">
                            <field name="description" placeholder="Thêm mô tả..."/>
                        </page>
                        <page string="Ghi chú" name="notes">
                            <field name="note" placeholder="Ghi chú nội bộ..."/>
                        </page>
                        <page string="Nhãn" name="tags">
                            <field name="tag_ids" widget="many2many_tags" options="{'color_field': 'color'}"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ============================================================ -->
    <!-- PIVOT VIEW — Theme Demo -->
    <!-- ============================================================ -->
    <record id="t4_theme_demo_view_pivot" model="ir.ui.view">
        <field name="name">t4.theme.demo.pivot</field>
        <field name="model">t4.theme.demo</field>
        <field name="arch" type="xml">
            <pivot>
                <field name="stage" type="row"/>
                <field name="priority" type="col"/>
                <field name="amount" type="measure"/>
            </pivot>
        </field>
    </record>

    <!-- ============================================================ -->
    <!-- GRAPH VIEW — Theme Demo -->
    <!-- ============================================================ -->
    <record id="t4_theme_demo_view_graph" model="ir.ui.view">
        <field name="name">t4.theme.demo.graph</field>
        <field name="model">t4.theme.demo</field>
        <field name="arch" type="xml">
            <graph type="bar">
                <field name="stage"/>
                <field name="amount" type="measure"/>
            </graph>
        </field>
    </record>

    <!-- ============================================================ -->
    <!-- ACTION (used internally by theme settings) -->
    <!-- ============================================================ -->
    <record id="t4_theme_demo_action" model="ir.actions.act_window">
        <field name="name">Demo giao diện</field>
        <field name="res_model">t4.theme.demo</field>
        <field name="view_mode">kanban,list,form,pivot,graph</field>
    </record>

</odoo>
