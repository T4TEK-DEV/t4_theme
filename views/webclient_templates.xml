<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- ================================================================
         T4 Theme — Webclient Template Overrides
         Adapted from udoo_om_ux patterns for Odoo 19.
         ================================================================ -->

    <!-- 1. Favicon: use company logo instead of default Odoo icon -->
    <template id="t4_favicon" inherit_id="web.layout" name="T4 Favicon">
        <xpath expr="//link[@rel='shortcut icon']" position="replace">
            <link rel="shortcut icon" type="image/x-icon"
                  t-att-href="'/web/image/res.company/%s/logo' % request.env.company.id"/>
        </xpath>
    </template>

    <!-- 2. Theme-color meta tag for mobile browsers (dark-aware) -->
    <template id="t4_theme_color" inherit_id="web.webclient_bootstrap"
              name="T4 Theme Color Meta">
        <xpath expr="//meta[@name='theme-color']" position="replace">
            <meta name="theme-color"
                  t-att-content="'#111827' if request.httprequest.cookies.get('color_scheme') == 'dark' else '#262626'"/>
        </xpath>
    </template>

    <!-- 3. Login page: force light mode class on body -->
    <template id="t4_login_light" inherit_id="web.login_layout"
              name="T4 Login Light Mode">
        <xpath expr="//t[@t-call='web.frontend_layout']" position="attributes">
            <attribute name="body_classname.f">bg-100 light-dm</attribute>
        </xpath>
    </template>

    <!-- 4. Hide "Don't have an account?" signup link on login -->
    <template id="t4_hide_signup" inherit_id="auth_signup.login"
              name="T4 Hide Signup Link" active="True">
        <xpath expr="//a[@t-if='signup_enabled']" position="replace">
            <!-- Signup link hidden by T4 Theme -->
        </xpath>
    </template>

    <!-- 5. Hide superuser login button (inside debug conditional) -->
    <template id="t4_hide_superuser" inherit_id="web.login"
              name="T4 Hide Superuser Login">
        <xpath expr="//button[@name='redirect']/.." position="replace">
            <!-- Superuser login hidden by T4 Theme -->
        </xpath>
    </template>

    <!-- 6. Replace login footer: hide DB manager + replace Odoo branding -->
    <template id="t4_login_branding" inherit_id="web.login_layout"
              name="T4 Login Custom Branding">
        <!-- Hide "Manage Databases" link -->
        <xpath expr="//a[@href='/web/database/manager']" position="replace">
            <!-- DB manager hidden by T4 Theme -->
        </xpath>
        <!-- Replace "Powered by Odoo" with company name -->
        <xpath expr="//a[@target='_blank'][last()]" position="replace">
            <span class="text-muted" t-out="request.env.company.name"/>
        </xpath>
    </template>

    <!-- 7. Company logo views: add light/dark logo fields -->
    <record id="t4_res_company_logo_form" model="ir.ui.view">
        <field name="name">res.company.form.inherit.t4.theme.logo</field>
        <field name="model">res.company</field>
        <field name="inherit_id" ref="base.view_company_form"/>
        <field name="priority">99</field>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='logo']/.." position="after">
                <group string="T4 Theme Logos" name="t4_logos"
                       groups="base.group_system">
                    <field name="t4_logo_light" widget="image"
                           options="{'size': [200, 100]}"/>
                    <field name="t4_logo_dark" widget="image"
                           options="{'size': [200, 100]}"/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
